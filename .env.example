# Neon PostgreSQL (required)
# Get this from https://console.neon.tech → your project → Connection string
# Vercel Neon integration may set POSTGRES_URL instead — both are supported.
DATABASE_URL=
# POSTGRES_URL=

# App login (required) — protects all pages except /login
APP_USERNAME=
APP_PASSWORD=

# MEXC API (required for scanner)
MEXC_API_KEY=
MEXC_API_SECRET=

# Cron secret — required for /api/cron only (not needed for GUI "Run Scan Now")
# Hobby Vercel plan: max 1 cron/day (vercel.json = daily 2pm UTC backup).
# For every-15-min scans on Hobby, set up free external cron at cron-job.org:
#   URL:    GET https://your-app.vercel.app/api/cron
#   Header: Authorization: Bearer <CRON_SECRET>
#   Every 15 minutes
CRON_SECRET=

# Optional — chart analyzer only (/analyzer page)
ANTHROPIC_API_KEY=

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional scanner configuration (JSON string)
# SCANNER_CONFIG={"watchlist":["BTC_USDT","ETH_USDT"],"candleInterval":"15m","rollingWindowHours":3}
