# Neon PostgreSQL (required)
# Get this from https://console.neon.tech → your project → Connection string
# Vercel Neon integration may set POSTGRES_URL instead — both are supported.
DATABASE_URL=
# POSTGRES_URL=

# App login (required) — protects all pages except /login
APP_USERNAME=
APP_PASSWORD=

# MEXC API (required for scanner)
MEXC_API_KEY=
MEXC_API_SECRET=

# Cron + AI (required)
CRON_SECRET=
ANTHROPIC_API_KEY=

# Optional Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Optional scanner configuration (JSON string)
# SCANNER_CONFIG={"watchlist":["BTC_USDT","ETH_USDT"],"candleInterval":"15m","rollingWindowHours":3}
